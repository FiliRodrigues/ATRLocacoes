# ============================================================
# ATR Locações — Environment Variables (example)
# ============================================================
# Copie este arquivo para .env.local e preencha com valores reais.
# NUNCA versione .env.local (já está no .gitignore).

# === Supabase (obrigatório) ===
SUPABASE_URL=
SUPABASE_ANON_KEY=

# === Anthropic (IA Assistant) ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MODEL_LIGHT=claude-haiku-4-5-20251001

# === Z-API (WhatsApp) ===
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
ZAPI_BASE_URL=https://api.z-api.io/instances

# === Webhook Security ===
AI_AGENT_WEBHOOK_SECRET=
WHATSAPP_WEBHOOK_SECRET=
